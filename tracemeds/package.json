{
  "name": "tracemeds",
  "version": "1.0.0",
  "description": "Multi-tenant Drug Supply Chain Management Platform",
  "repository": "https://github.com/healthcare/tracemeds",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@sap/cds": "^9.7.1",
    "express": "^4"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.7.1",
    "better-sqlite3": "^9"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "build": "cds build --production"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sql"
      },
      "auth": {
        "kind": "xsuaa"
      },
      "[development]": {
        "auth": {
          "kind": "mocked",
          "users": {
            "alice": {
              "password": "alice",
              "roles": [
                "SystemAdmin"
              ]
            },
            "bob": {
              "password": "bob",
              "roles": [
                "HospitalUser"
              ],
              "attr": {
                "HospitalID": [
                  "H001"
                ]
              }
            },
            "charlie": {
              "password": "charlie",
              "roles": [
                "ProcurementOfficer"
              ]
            },
            "diana": {
              "password": "diana",
              "roles": [
                "InventoryManager"
              ]
            }
          }
        }
      }
    },
    "hana": {
      "deploy-format": "hdbtable"
    }
  }
}