{
	"_version": "1.82.0",
	"sap.app": {
		"id": "inventoryui",
		"type": "application",
		"i18n": {
			"bundleUrl": "i18n/i18n.properties",
			"supportedLocales": [
				""
			]
		},
		"applicationVersion": {
			"version": "0.0.1"
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"resources": "resources.json",
		"sourceTemplate": {
			"id": "@sap/generator-fiori:list-report-object-page",
			"version": "1.20.4",
			"toolsId": "aa000c2e-5e96-41fb-9090-3ca0c130daa0"
		},
		"dataSources": {
			"mainService": {
				"uri": "/odata/v4/InventoryService/",
				"type": "OData",
				"settings": {
					"annotations": [],
					"odataVersion": "4.01"
				}
			}
		},
		"crossNavigation": {
			"inbounds": {
				"Inventory-display": {
					"semanticObject": "Inventory",
					"action": "display",
					"title": "{{appTitle}}",
					"subTitle": "{{appDescription}}",
					"icon": "sap-icon://medicines",
					"signature": {
						"parameters": {},
						"additionalParameters": "allowed"
					}
				}
			}
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "",
			"favIcon": "",
			"phone": "",
			"phone@2": "",
			"tablet": "",
			"tablet@2": ""
		},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"flexEnabled": true,
		"dependencies": {
			"minUI5Version": "1.145.0",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.fe.core": {},
				"sap.fe.templates": {}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "inventoryui.i18n.i18n",
					"supportedLocales": [
						""
					]
				}
			},
			"": {
				"dataSource": "mainService",
				"preload": true,
				"settings": {
					"operationMode": "Server",
					"autoExpandSelect": true,
					"earlyRequests": true
				}
			},
			"@i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"uri": "i18n/i18n.properties",
				"settings": {
					"supportedLocales": [
						""
					]
				}
			}
		},
		"resources": {
			"css": []
		},
		"routing": {
			"config": {},
			"routes": [
				{
					"name": "InventoryRecordsList",
					"pattern": ":?query:",
					"target": "InventoryRecordsList"
				},
				{
					"name": "InventoryRecordsObjectPage",
					"pattern": "InventoryRecords({key}):?query:",
					"target": "InventoryRecordsObjectPage"
				}
			],
			"targets": {
				"InventoryRecordsList": {
					"type": "Component",
					"id": "InventoryRecordsList",
					"name": "sap.fe.templates.ListReport",
					"options": {
						"settings": {
							"entitySet": "InventoryRecords",
							"navigation": {
								"InventoryRecords": {
									"detail": {
										"route": "InventoryRecordsObjectPage"
									}
								}
							}
						}
					}
				},
				"InventoryRecordsObjectPage": {
					"type": "Component",
					"id": "InventoryRecordsObjectPage",
					"name": "sap.fe.templates.ObjectPage",
					"options": {
						"settings": {
							"entitySet": "InventoryRecords",
							"editableHeaderContent": false
						}
					}
				}
			}
		},
		"flexBundle": false
	},
	"sap.fe": {
		"app": {
			"enableLazyLoading": true
		}
	}
}